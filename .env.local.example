NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Calendar Integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp API (optional - para envio automático de códigos)
# Compatível com Evolution API, Z-API, ou qualquer API com POST { phone, message }
# WHATSAPP_API_URL=https://sua-api-whatsapp.com/send
# WHATSAPP_API_KEY=seu-token-aqui

# Email (Resend) - para envio de propostas por email
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=Local da FSS <noreply@fullsales.com.br>
